// ----------------------
// Example file
// ----------------------

enum ErrCode {
    ErrOk = 0
    PARAM_ERROR = 1003
}

type Response<T> {
    ErrCode errno = ErrCode.PARAM_ERROR
    string errmsg
    T data
}

type ManagerReq {
    string id
}

type Manager {
    string name
    int? age
    Address
}

type Address {
    string city
    string? street
}

rpc GetManager(ManagerReq) ResponseManager {
    method="GET"
    path="/user"
}

type ResponseManager Response<Manager?>