// stream.idl

type StreamReq {
    string id
}

type StreamResp {
    string id
    string data
    Payload payload
}

oneof Payload {
    Payload_1
    Payload_2
    Payload_3
}

type Payload_1 {}
type Payload_2 {}
type Payload_3 {}

// Streaming ...
rpc Stream(StreamReq) stream<StreamResp> {
    method="GET"
    path="/stream"
    contentType="form"
    summary="Streaming"
}